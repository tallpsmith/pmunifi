{
  "uid": "pcp-unifi-ap-radio-performance",
  "title": "UniFi AP Radio Performance",
  "description": "Per-radio client counts, channel assignments, TX retries, and satisfaction scores for UniFi access points",
  "tags": ["pcp", "unifi"],
  "editable": true,
  "schemaVersion": 39,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "DS_PCP",
        "type": "datasource",
        "query": "pcp",
        "current": {},
        "hide": 0
      },
      {
        "name": "site_name",
        "type": "query",
        "datasource": { "uid": "${DS_PCP}" },
        "query": "label_values(unifi.site.num_sta, site_name)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Clients Per Radio",
      "type": "timeseries",
      "datasource": { "uid": "${DS_PCP}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "unifi.ap.num_sta{site_name=\"$site_name\"}",
          "legendFormat": "{{instance}}",
          "datasource": { "uid": "${DS_PCP}" }
        }
      ]
    },
    {
      "id": 2,
      "title": "Radio Channel Assignments",
      "type": "table",
      "datasource": { "uid": "${DS_PCP}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "center" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Channel", "desc": false }] },
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "instance": "Radio",
              "Value #A": "Channel",
              "Value #B": "Radio Type",
              "Value #C": "Clients"
            }
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "expr": "unifi.ap.channel{site_name=\"$site_name\"}",
          "format": "table",
          "datasource": { "uid": "${DS_PCP}" }
        },
        {
          "refId": "B",
          "expr": "unifi.ap.radio_type{site_name=\"$site_name\"}",
          "format": "table",
          "datasource": { "uid": "${DS_PCP}" }
        },
        {
          "refId": "C",
          "expr": "unifi.ap.num_sta{site_name=\"$site_name\"}",
          "format": "table",
          "datasource": { "uid": "${DS_PCP}" }
        }
      ]
    },
    {
      "id": 3,
      "title": "TX Retries Rate",
      "type": "timeseries",
      "datasource": { "uid": "${DS_PCP}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "color": { "mode": "continuous-GrYlRd" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(unifi.ap.tx_retries{site_name=\"$site_name\"})",
          "legendFormat": "{{instance}}",
          "datasource": { "uid": "${DS_PCP}" }
        }
      ]
    },
    {
      "id": 4,
      "title": "Radio Satisfaction Score",
      "type": "gauge",
      "datasource": { "uid": "${DS_PCP}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "horizontal"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "unifi.ap.satisfaction{site_name=\"$site_name\"}",
          "legendFormat": "{{instance}}",
          "datasource": { "uid": "${DS_PCP}" }
        }
      ]
    }
  ]
}
